FROM rabbitmq:4.2-management-alpine

# Cria usuário Fiap (UID 1001, por exemplo)
RUN addgroup -S fiap && adduser -S fiap -G fiap --uid 1001

# Permissões necessárias
RUN chown -R fiap:fiap /var/lib/rabbitmq

# Configurações (caso inclua arquivos de config)
RUN mkdir -p /etc/rabbitmq && \
    chown -R fiap:fiap /etc/rabbitmq

# Porta de logs
RUN mkdir -p /var/log/rabbitmq && \
    chown -R fiap:fiap /var/log/rabbitmq

# Define usuário não-root
USER fiap

# Roda o RabbitMQ
CMD ["rabbitmq-server"]